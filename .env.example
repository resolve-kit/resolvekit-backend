# PostgreSQL
POSTGRES_USER=agent
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent

# Backend
IAA_DATABASE_URL=postgresql+asyncpg://agent:postgres@db:5432/agent
IAA_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
IAA_JWT_ALGORITHM=HS256
IAA_JWT_EXPIRE_MINUTES=1440
IAA_ENCRYPTION_KEY=change-me-generate-with-python-fernet
IAA_CHAT_CAPABILITY_SECRET=change-me-generate-with-openssl-rand-hex-32
IAA_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:5173"]
IAA_DEBUG=false
IAA_ALLOW_LEGACY_WS_API_KEY=true
IAA_REDIS_URL=redis://redis:6379/0
IAA_WS_OWNER_TTL_SECONDS=120
IAA_WS_OUTBOX_TTL_SECONDS=300
IAA_WS_TOOL_RESULT_TTL_SECONDS=300

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002
NEXT_PUBLIC_RESOLVEKIT_ENABLED=false
RESOLVEKIT_KEY=iaa_your_key_here
NEXT_PUBLIC_RESOLVEKIT_AGENT_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://agent:postgres@db:5432/agent

# Knowledge base service
KBS_DATABASE_URL=postgresql+asyncpg://agent:postgres@kb-db:5432/knowledge_bases
KBS_POSTGRES_DB=knowledge_bases
KBS_SERVICE_JWT_SIGNING_KEY=change-me-kb-service-signing-key
KBS_SERVICE_JWT_AUDIENCE=kb-service
KBS_ENCRYPTION_KEY=change-me-generate-with-python-fernet
KBS_USE_CRAWL4AI=true
KBS_CRAWL4AI_HEADLESS=true
KBS_CRAWL4AI_BASE_DIRECTORY=/tmp/crawl4ai
KBS_UPLOAD_MAX_FILE_BYTES=26214400
KBS_UPLOAD_ALLOWED_EXTENSIONS=.txt,.md,.markdown,.pdf,.doc,.docx,.ppt,.pptx,.rtf,.odt,.html,.htm,.csv,.tsv,.xlsx,.xls,.json,.xml,.yaml,.yml
KBS_UPLOAD_OCR_ENABLED=false
