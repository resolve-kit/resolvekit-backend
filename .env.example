# PostgreSQL
POSTGRES_USER=agent
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent

# Backend
IAA_DATABASE_URL=postgresql+asyncpg://agent:postgres@db:5432/agent
IAA_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
IAA_JWT_ALGORITHM=HS256
IAA_JWT_EXPIRE_MINUTES=1440
# Required in production. The dashboard can derive a local-only fallback from
# IAA_JWT_SECRET during Next.js development when this value is missing or invalid.
IAA_ENCRYPTION_KEY=change-me-generate-with-python-fernet
IAA_CHAT_CAPABILITY_SECRET=change-me-generate-with-openssl-rand-hex-32
IAA_SDK_CLIENT_TOKEN_SECRET=change-me-generate-with-openssl-rand-hex-32
IAA_SDK_CLIENT_TOKEN_TTL_SECONDS=900
IAA_SDK_CLIENT_TOKEN_RATE_LIMIT_PER_MINUTE=60
IAA_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:5173"]
IAA_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
IAA_DEBUG=false
IAA_ALLOW_LEGACY_WS_API_KEY=true
IAA_REDIS_URL=redis://redis:6379/0
IAA_WS_OWNER_TTL_SECONDS=120
IAA_WS_OUTBOX_TTL_SECONDS=300
IAA_WS_TOOL_RESULT_TTL_SECONDS=300
IAA_KNOWLEDGE_BASES_BASE_URL=http://kb-service:8100
IAA_KNOWLEDGE_BASES_SIGNING_KEY=change-me-kb-service-signing-key
IAA_KNOWLEDGE_BASES_AUDIENCE=kb-service
IAA_KNOWLEDGE_BASES_JWT_ALGORITHM=HS256
IAA_KNOWLEDGE_BASES_TIMEOUT_SECONDS=20
IAA_KNOWLEDGE_BASES_CONNECT_TIMEOUT_SECONDS=5

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_RESOLVEKIT_ENABLED=false
RESOLVEKIT_NEXTJS_SDK_PATH=/absolute/path/to/resolvekit-nextjs-sdk
RESOLVEKIT_KEY=iaa_your_key_here
# Optional server-side override for the dashboard token route. In docker compose,
# this must still use HTTPS unless it targets localhost.
RESOLVEKIT_SERVER_AGENT_BASE_URL=
NEXT_PUBLIC_RESOLVEKIT_AGENT_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://agent:postgres@db:5432/agent

# Knowledge base service
KBS_DATABASE_URL=postgresql+asyncpg://agent:postgres@kb-db:5432/knowledge_bases
KBS_POSTGRES_DB=knowledge_bases
KBS_SERVICE_JWT_SIGNING_KEY=change-me-kb-service-signing-key
KBS_SERVICE_JWT_AUDIENCE=kb-service
KBS_ENCRYPTION_KEY=change-me-generate-with-python-fernet
KBS_USE_CRAWL4AI=true
KBS_CRAWL4AI_HEADLESS=true
KBS_CRAWL4AI_BASE_DIRECTORY=/tmp/crawl4ai
KBS_UPLOAD_MAX_FILE_BYTES=26214400
KBS_UPLOAD_ALLOWED_EXTENSIONS=.txt,.md,.markdown,.pdf,.doc,.docx,.ppt,.pptx,.rtf,.odt,.html,.htm,.csv,.tsv,.xlsx,.xls,.json,.xml,.yaml,.yml
KBS_UPLOAD_OCR_ENABLED=false

# Public gateway / Caddy
# If another reverse proxy already owns :80/:443 on the VPS, bind ResolveKit's
# Caddy to loopback/high ports instead and proxy ResolveKit domains to the
# `resolvekit_prod_caddy` service on the shared Docker network.
GATEWAY_HTTP_BIND_ADDR=0.0.0.0
GATEWAY_HTTP_BIND_PORT=80
GATEWAY_HTTPS_BIND_ADDR=0.0.0.0
GATEWAY_HTTPS_BIND_PORT=443
RESOLVEKIT_MARKETING_HOST=resolvekit.app
RESOLVEKIT_CONSOLE_HOST=console.resolvekit.app
RESOLVEKIT_API_HOST=api.resolvekit.app
RESOLVEKIT_AGENT_HOST=agent.resolvekit.app
LETSENCRYPT_EMAIL=devops@resolvekit.app
