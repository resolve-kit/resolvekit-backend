# Public gateway listener (Dockerized Nginx)
GATEWAY_HTTP_BIND_ADDR=0.0.0.0
GATEWAY_HTTP_BIND_PORT=80
GATEWAY_HTTPS_BIND_ADDR=0.0.0.0
GATEWAY_HTTPS_BIND_PORT=443
NGINX_RELOAD_INTERVAL_SECONDS=60

# Public hostnames proxied by Nginx (must resolve to this machine for Let's Encrypt)
RESOLVEKIT_MARKETING_HOST=resolvekit-dev.example.com
RESOLVEKIT_CONSOLE_HOST=console.resolvekit-dev.example.com
RESOLVEKIT_API_HOST=api.resolvekit-dev.example.com
RESOLVEKIT_AGENT_HOST=agent.resolvekit-dev.example.com

# Let's Encrypt
LETSENCRYPT_EMAIL=devops@example.com
LETSENCRYPT_CERT_NAME=resolvekit-dev
# Keep this as 1 for initial testing to avoid Let's Encrypt rate limits.
# Set to 0 for trusted (browser-valid) certificates.
LETSENCRYPT_STAGING=1

# Public URLs embedded into website/dashboard bundles
NEXT_PUBLIC_DASHBOARD_URL=https://console.resolvekit-dev.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.resolvekit-dev.example.com
NEXT_PUBLIC_RESOLVEKIT_AGENT_BASE_URL=https://agent.resolvekit-dev.example.com

# Backend/browser CORS allowlists.
# If you change hostnames or gateway port, update these values to match.
IAA_CORS_ORIGINS=["https://resolvekit-dev.example.com","https://console.resolvekit-dev.example.com","https://api.resolvekit-dev.example.com"]
IAA_CORS_ALLOWED_ORIGINS=https://resolvekit-dev.example.com,https://console.resolvekit-dev.example.com
