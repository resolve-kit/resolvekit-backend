# Public gateway listener (Caddy)
# If another reverse proxy already owns public `:80/:443`, bind Caddy to
# loopback/high ports here and proxy your chosen public host to `resolvekit_prod_caddy`.
GATEWAY_HTTP_BIND_ADDR=0.0.0.0
GATEWAY_HTTP_BIND_PORT=80
GATEWAY_HTTPS_BIND_ADDR=0.0.0.0
GATEWAY_HTTPS_BIND_PORT=443

# Public host proxied by Caddy (must resolve to this machine for Let's Encrypt)
RESOLVEKIT_PUBLIC_HOST=support-dev.example.com

# Let's Encrypt (Caddy uses staging CA via Caddyfile.local-deploy)
LETSENCRYPT_EMAIL=devops@example.com

# Public URLs embedded into dashboard bundles.
# The default single-host self-host setup serves the dashboard at `/`,
# dashboard control-plane API at `/v1/*`, and agent runtime at `/agent/v1/*`.
NEXT_PUBLIC_DASHBOARD_URL=https://support-dev.example.com
NEXT_PUBLIC_API_BASE_URL=https://support-dev.example.com
NEXT_PUBLIC_IOS_SDK_REPO_URL=https://github.com/your-org/resolvekit-ios-sdk

# Backend/browser CORS allowlists.
# If you change hostnames or gateway port, update these values to match.
RK_CORS_ORIGINS=["https://support-dev.example.com"]
RK_CORS_ALLOWED_ORIGINS=https://support-dev.example.com
