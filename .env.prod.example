# Public gateway listener (Caddy)
# Direct/public edge: leave these on `0.0.0.0:80/443`.
# Shared edge behind `scout4me_balance`: bind Caddy to loopback/high ports
# instead (for example `127.0.0.1:18080` and `127.0.0.1:18443`) and let the
# outer nginx route your chosen service hosts to `resolvekit_prod_caddy`.
GATEWAY_HTTP_BIND_ADDR=0.0.0.0
GATEWAY_HTTP_BIND_PORT=80
GATEWAY_HTTPS_BIND_ADDR=0.0.0.0
GATEWAY_HTTPS_BIND_PORT=443

# Public service hostnames proxied by Caddy (must resolve to this machine for Let's Encrypt)
RESOLVEKIT_CONSOLE_HOST=console.example.com
RESOLVEKIT_API_HOST=api.example.com
RESOLVEKIT_AGENT_HOST=agent.example.com

# Let's Encrypt
LETSENCRYPT_EMAIL=devops@example.com

# Public URLs embedded into dashboard bundles.
# Recommended production topology uses dedicated hosts for the dashboard shell,
# dashboard control-plane API, and agent runtime.
NEXT_PUBLIC_DASHBOARD_URL=https://console.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Backend/browser CORS allowlists
IAA_CORS_ORIGINS=["https://console.example.com","https://api.example.com"]
IAA_CORS_ALLOWED_ORIGINS=https://console.example.com
