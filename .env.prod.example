# Public gateway listener (Caddy)
# Direct/public edge: leave these on `0.0.0.0:80/443`.
# Shared edge behind `scout4me_balance`: bind Caddy to loopback/high ports
# instead (for example `127.0.0.1:18080` and `127.0.0.1:18443`) and let the
# outer nginx route all `*.resolvekit.app` hosts to `resolvekit_prod_caddy`.
GATEWAY_HTTP_BIND_ADDR=0.0.0.0
GATEWAY_HTTP_BIND_PORT=80
GATEWAY_HTTPS_BIND_ADDR=0.0.0.0
GATEWAY_HTTPS_BIND_PORT=443

# Public hostnames proxied by Caddy (must resolve to this machine for Let's Encrypt)
RESOLVEKIT_MARKETING_HOST=resolvekit.app
RESOLVEKIT_CONSOLE_HOST=console.resolvekit.app
RESOLVEKIT_API_HOST=api.resolvekit.app
RESOLVEKIT_AGENT_HOST=agent.resolvekit.app

# Let's Encrypt
LETSENCRYPT_EMAIL=devops@resolvekit.app

# Public URLs embedded into website/dashboard bundles
NEXT_PUBLIC_DASHBOARD_URL=https://console.resolvekit.app
NEXT_PUBLIC_API_BASE_URL=https://api.resolvekit.app
NEXT_PUBLIC_RESOLVEKIT_AGENT_BASE_URL=https://agent.resolvekit.app

# Backend/browser CORS allowlists
IAA_CORS_ORIGINS=["https://resolvekit.app","https://console.resolvekit.app","https://api.resolvekit.app"]
IAA_CORS_ALLOWED_ORIGINS=https://resolvekit.app,https://console.resolvekit.app
