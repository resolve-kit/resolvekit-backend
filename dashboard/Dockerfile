FROM node:22-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
COPY prisma ./prisma
RUN npm ci --legacy-peer-deps --no-audit --no-fund

FROM node:22-alpine AS build

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_API_BASE_URL=
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_IOS_SDK_REPO_URL=
ENV NEXT_PUBLIC_IOS_SDK_REPO_URL=$NEXT_PUBLIC_IOS_SDK_REPO_URL
ARG NEXT_PUBLIC_ANDROID_SDK_REPO_URL=
ENV NEXT_PUBLIC_ANDROID_SDK_REPO_URL=$NEXT_PUBLIC_ANDROID_SDK_REPO_URL
ARG NEXT_PUBLIC_IOS_SAMPLE_DMG_URL=
ENV NEXT_PUBLIC_IOS_SAMPLE_DMG_URL=$NEXT_PUBLIC_IOS_SAMPLE_DMG_URL
ARG NEXT_PUBLIC_ANDROID_SAMPLE_DEBUG_APK_URL=
ENV NEXT_PUBLIC_ANDROID_SAMPLE_DEBUG_APK_URL=$NEXT_PUBLIC_ANDROID_SAMPLE_DEBUG_APK_URL
ARG NEXT_PUBLIC_ANDROID_SAMPLE_RELEASE_APK_URL=
ENV NEXT_PUBLIC_ANDROID_SAMPLE_RELEASE_APK_URL=$NEXT_PUBLIC_ANDROID_SAMPLE_RELEASE_APK_URL
RUN npm run build

FROM node:22-alpine AS runtime

WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=build /app/package.json ./package.json
COPY --from=build /app/.next ./.next
COPY --from=build /app/public ./public
COPY --from=build /app/node_modules ./node_modules

EXPOSE 3000

CMD ["npm", "run", "start"]
