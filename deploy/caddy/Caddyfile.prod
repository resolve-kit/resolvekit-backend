{
	email {$LETSENCRYPT_EMAIL}
}

{$RESOLVEKIT_AGENT_HOST} {
	reverse_proxy backend:8000 {
		flush_interval -1
		buffer_responses false
		transport http {
			read_timeout 0
			write_timeout 0
		}
	}
	header Alt-Svc "h3=\":443\"; ma=2592000"
}

{$RESOLVEKIT_CONSOLE_HOST} {
	reverse_proxy dashboard:3000
}

{$RESOLVEKIT_API_HOST} {
	reverse_proxy api:3000
}

{$RESOLVEKIT_MARKETING_HOST} {
	reverse_proxy website:3000
}
